# Supabase Configuration
SUPABASE_URL="https://example-project.supabase.co"
SUPABASE_ANON_KEY="replace-with-anon-key"
SUPABASE_SERVICE_ROLE_KEY="replace-with-service-role-key"

# Nuxt Supabase Module (uses these names)
NUXT_PUBLIC_SUPABASE_URL="https://example-project.supabase.co"
NUXT_PUBLIC_SUPABASE_KEY="replace-with-anon-key"

# Spotify Configuration
SPOTIFY_CLIENT_ID="replace-with-spotify-client-id"
SPOTIFY_CLIENT_SECRET="replace-with-spotify-client-secret"

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/soundlog"

# App Configuration
NUXT_PUBLIC_SITE_URL="http://localhost:3000"
